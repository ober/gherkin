(defcompile-method (apply-generate-method-specializers)
  (::generate-method-specializers ::identity) () 'final:
  (%\x23;begin xform-begin%)
  (%\x23;begin-syntax xform-begin-syntax%)
  (%\x23;module xform-module%)
  (%\x23;define-values
    generate-method-specializers-define-values%))

(defcompile-method (apply-extract-receiver) (::extract-receiver ::false) ()
  'final: (%\x23;begin apply-last-begin%)
  (%\x23;begin-annotation extract-receiver-begin-annotation%)
  (%\x23;let-values apply-body-last-let-values%)
  (%\x23;letrec-values apply-body-last-let-values%)
  (%\x23;letrec*-values apply-body-last-let-values%)
  (%\x23;if extract-receiver-if%))

(defcompile-method
 (apply-collect-object-refs 'receiver: receiver 'methods:
   methods 'slots: slots)
 (::collect-object-refs ::void) (receiver methods slots)
 'final: (%\x23;begin apply-begin%)
 (%\x23;begin-annotation apply-begin-annotation%)
 (%\x23;lambda apply-body-lambda%)
 (%\x23;case-lambda apply-body-case-lambda%)
 (%\x23;let-values apply-body-let-values%)
 (%\x23;letrec-values apply-body-let-values%)
 (%\x23;letrec*-values apply-body-let-values%)
 (%\x23;call collect-object-refs-call%)
 (%\x23;if apply-operands) (%\x23;set! apply-body-setq%)
 (%\x23;struct-ref apply-operands)
 (%\x23;struct-set! apply-operands)
 (%\x23;struct-direct-ref apply-operands)
 (%\x23;struct-direct-set! apply-operands)
 (%\x23;struct-unchecked-ref apply-operands)
 (%\x23;struct-unchecked-set! apply-operands))

(defcompile-method
