(define (greatest-common-type stx type-a type-b)
  (define (common-e left right)
    (let loop ([rest left])
      (let ([#{match-val dpuuv4a3mobea70icwo8nvdax-4742} rest])
        (if (pair? #{match-val dpuuv4a3mobea70icwo8nvdax-4742})
            (let ([#{hd dpuuv4a3mobea70icwo8nvdax-4743} (car #{match-val dpuuv4a3mobea70icwo8nvdax-4742})]
                  [#{tl dpuuv4a3mobea70icwo8nvdax-4744} (cdr #{match-val dpuuv4a3mobea70icwo8nvdax-4742})])
              (let ([klass-name #{hd dpuuv4a3mobea70icwo8nvdax-4743}])
                (let ([rest #{tl dpuuv4a3mobea70icwo8nvdax-4744}])
                  (begin
                    (if (memq klass-name right)
                        (optimizer-resolve-class stx klass-name)
                        (loop rest))))))
            (begin (optimizer-resolve-class stx 't::t))))))
  (define (common-tail precedence-list-a precedence-list-b)
    (let* ([rev-precedence-list-a (reverse precedence-list-a)])
      (let* ([rev-precedence-list-b (reverse precedence-list-b)])
        (let loop ([rest-a rev-precedence-list-a]
                   [rest-b rev-precedence-list-b]
                   [result #f])
          (let ([#{match-val dpuuv4a3mobea70icwo8nvdax-4745} rest-a])
            (if (pair? #{match-val dpuuv4a3mobea70icwo8nvdax-4745})
                (let ([#{hd dpuuv4a3mobea70icwo8nvdax-4746} (car #{match-val dpuuv4a3mobea70icwo8nvdax-4745})]
                      [#{tl dpuuv4a3mobea70icwo8nvdax-4747} (cdr #{match-val dpuuv4a3mobea70icwo8nvdax-4745})])
                  (let ([super-a #{hd dpuuv4a3mobea70icwo8nvdax-4746}])
                    (let ([rest-a #{tl dpuuv4a3mobea70icwo8nvdax-4747}])
                      (begin
                        (let ([#{match-val dpuuv4a3mobea70icwo8nvdax-4748} rest-b])
                          (if (pair?
                                #{match-val dpuuv4a3mobea70icwo8nvdax-4748})
                              (let ([#{hd dpuuv4a3mobea70icwo8nvdax-4749} (car #{match-val dpuuv4a3mobea70icwo8nvdax-4748})]
                                    [#{tl dpuuv4a3mobea70icwo8nvdax-4750} (cdr #{match-val dpuuv4a3mobea70icwo8nvdax-4748})])
                                (let ([super-b #{hd dpuuv4a3mobea70icwo8nvdax-4749}])
                                  (let ([rest-b #{tl dpuuv4a3mobea70icwo8nvdax-4750}])
                                    (begin
                                      (if (eq? super-a super-b)
                                          (loop rest-a rest-b super-a)
                                          (and result
                                               (optimizer-resolve-class
                                                 stx
                                                 result)))))))
                              (begin
                                (and result
                                     (optimizer-resolve-class
                                       stx
                                       result)))))))))
                (begin
                  (and result (optimizer-resolve-class stx result)))))))))
  (cond
    [(or (not type-a) (not type-b))
     (optimizer-resolve-class stx 't::t)]
    [(!type-subtype? type-a type-b) type-b]
    [(!type-subtype? type-b type-a) type-a]
    [(and (!class? type-a) (!class? type-b))
     (let* ([precedence-list-a (!class-precedence-list type-a)])
       (let* ([precedence-list-b (!class-precedence-list type-b)])
         (cond
           [(> (length precedence-list-a) (length precedence-list-b))
            (common-e precedence-list-b precedence-list-a)]
           [(< (length precedence-list-a) (length precedence-list-b))
            (common-e precedence-list-a precedence-list-b)]
           [else (common-tail precedence-list-a precedence-list-b)])))]
    [(and (eq? (!type-id type-a) 'procedure)
          (eq? (!type-id type-b) 'procedure))
     (optimizer-resolve-class stx 'procedure::t)]
    [else #f]))

