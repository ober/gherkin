(define lift-case-lambda-clauses
  (case-lambda
    [(stx id clauses)
     (let* ([gensym? #f])
       (let lp ([rest clauses]
                [ids (list)]
                [impls (list)]
                [clauses (list)])
         (let ([#{match-val dpuuv4a3mobea70icwo8nvdax-5242} rest])
           (if (pair? #{match-val dpuuv4a3mobea70icwo8nvdax-5242})
               (let ([#{hd dpuuv4a3mobea70icwo8nvdax-5243} (car #{match-val dpuuv4a3mobea70icwo8nvdax-5242})]
                     [#{tl dpuuv4a3mobea70icwo8nvdax-5244} (cdr #{match-val dpuuv4a3mobea70icwo8nvdax-5242})])
                 (let ([clause #{hd dpuuv4a3mobea70icwo8nvdax-5243}])
                   (let ([rest #{tl dpuuv4a3mobea70icwo8nvdax-5244}])
                     (begin
                       (if (dispatch-lambda-form? clause)
                           (lp rest ids impls (cons clause clauses))
                           (let ([#{ast-val dpuuv4a3mobea70icwo8nvdax-5245} clause])
                             (let ([#{fail dpuuv4a3mobea70icwo8nvdax-5246} (lambda ()
                                                                             (__raise-syntax-error
                                                                               #f
                                                                               "Bad syntax; malformed ast clause"
                                                                               #{ast-val dpuuv4a3mobea70icwo8nvdax-5245}))])
                               (if (__AST-pair?
                                     #{ast-val dpuuv4a3mobea70icwo8nvdax-5245})
                                   (let* ([#{etgt dpuuv4a3mobea70icwo8nvdax-5247} (__AST-e
                                                                                    #{ast-val dpuuv4a3mobea70icwo8nvdax-5245})]
                                          [#{ehd dpuuv4a3mobea70icwo8nvdax-5248} (\x23;\x23;car
                                                                                   #{etgt dpuuv4a3mobea70icwo8nvdax-5247})]
                                          [#{etl dpuuv4a3mobea70icwo8nvdax-5249} (\x23;\x23;cdr
                                                                                   #{etgt dpuuv4a3mobea70icwo8nvdax-5247})])
