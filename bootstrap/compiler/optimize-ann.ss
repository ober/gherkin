(define (optimize-syntax-case-body stx expr negation
         clauses)
  (define (normalize clauses)
    (let ([#{tmp dpuuv4a3mobea70icwo8nvdax-8163} clauses])
      (let ([(\x40;list id . kont) (car #{tmp dpuuv4a3mobea70icwo8nvdax-8163})]
            [rest (cdr #{tmp dpuuv4a3mobea70icwo8nvdax-8163})])
        (cons* (cons* #f kont) rest))))
  (parameterize ([current-expander-context
                  (make-local-context)])
    (let* ([id (make-symbol (gensym "__stx"))])
      (let* ([id (core-quote-syntax id)])
        (let* ([_ (core-bind-runtime! id)])
          (call-with-values
            (lambda ()
              (optimize-syntax-case-clauses clauses (car negation)))
            (lambda (clauses konts)
              (let* ([clauses (map (lambda (#{cut-arg dpuuv4a3mobea70icwo8nvdax-8164}
                                            #{cut-arg dpuuv4a3mobea70icwo8nvdax-8165})
                                     (optimize-syntax-case-closure
                                       #{cut-arg dpuuv4a3mobea70icwo8nvdax-8164}
                                       #{cut-arg dpuuv4a3mobea70icwo8nvdax-8165}
                                       id))
                                   clauses
                                   (list
                                     (map car (cdr clauses))
                                     ...
                                     (car negation)))])
                (let* ([clauses (normalize clauses)])
                  (let* ([negation (optimize-syntax-case-closure
                                     negation
                                     #f
                                     id)])
                    (let* ([body (optimize-match-body
                                   stx
                                   negation
                                   clauses
                                   konts)])
                      (xform-wrap-source
                        (list
                          '%\x23;let-values
                          (list (list (list id) expr))
                          body)
                        stx))))))))))))

