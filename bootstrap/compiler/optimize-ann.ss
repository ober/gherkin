(defcompile-method (apply-optimize-annotated)
  (::optimize-annotated ::basic-xform) () 'final:
  (%\x23;begin-annotation optimize-annotation%))

(defcompile-method (apply-generate-runtime-repr)
  (::generate-runtime-repr ::generate-runtime) () 'final:
  (%\x23;quote-syntax identity-method))

(defcompile-method (apply-push-match-vars 'vars: vars 'K: K) ::push-match-vars
  (vars K) 'final: (%\x23;lambda xform-lambda%)
  (%\x23;let-values push-match-vars-let-values%)
  (%\x23;letrec-values push-match-vars-stop)
  (%\x23;if push-match-vars-if%)
  (%\x23;call push-match-vars-call%)
  (%\x23;begin-annotation push-match-vars-stop))

